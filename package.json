{
  "name": "lucidity",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @lucidity/api dev",
    "dev:mobile": "pnpm --filter @lucidity/mobile dev",
    "dev:web": "pnpm --filter @lucidity/web dev",
    "ios:local": "pnpm --filter @lucidity/mobile ios:local",
    "ios:prod": "pnpm --filter @lucidity/mobile ios:prod",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.4",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=18"
  },
  "version": "1.0.0",
  "dependencies": {
    "expo": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2"
  }
}