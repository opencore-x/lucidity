{
  "name": "lucidity",
  "private": true,
  "scripts": {
    "postinstall": "npx -y skills install || true",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@lucidity/api...",
    "dev:mobile": "turbo run dev --filter=@lucidity/mobile",
    "dev:web": "turbo run dev --filter=@lucidity/web",
    "dev:daemon": "turbo run dev --filter=@lucidity/daemon...",
    "ios:local": "pnpm --filter @lucidity/mobile ios:local",
    "ios:prod": "pnpm --filter @lucidity/mobile ios:prod",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.4",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1",
      "@expo/dom-webview": "56.0.5"
    }
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=18"
  },
  "version": "0.1.0"
}