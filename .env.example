# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Clerk (Server)
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Mobile (Expo public vars)
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# MCP server (Claude integration)
# Generate the key in the Lucidity app: Settings → API Key → Generate.
# LUCIDITY_API_URL defaults to the hosted API; set it to http://localhost:3000 for local dev.
LUCIDITY_API_KEY=luc_xxx
LUCIDITY_API_URL=https://api.lucidity.my
